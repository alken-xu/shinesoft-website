# メール送信設定（お問い合わせフォーム）
# 未設定の場合はフォーム送信はログ出力のみになります

# ─────────────────────────────────────────
# Gmail SMTP 設定（本番・ローカル共通）
# Googleアカウントのアプリパスワード（16文字）を使用
# 取得手順: Googleアカウント → セキュリティ → 2段階認証を有効化
#           → アプリパスワード → 「その他」で生成
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# 送信元アドレス（SMTP_USERと同じGmailアドレス）
SMTP_FROM=your-gmail@gmail.com

# 問い合わせ受信先メールアドレス（社内担当者）
CONTACT_TO_EMAIL=contact@shinesoft.co.jp
