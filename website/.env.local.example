# メール送信設定（お問い合わせフォーム）
# 未設定の場合はフォーム送信はログ出力のみになります

SMTP_HOST=smtp.shinesoft.co.jp
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-name@shinesoft.co.jp
SMTP_PASS=your-password

# 送信元アドレス（SMTP_USERと同じアドレス）
SMTP_FROM=your-name@shinesoft.co.jp

# 問い合わせ受信先メールアドレス（社内担当者）
CONTACT_TO_EMAIL=contact@shinesoft.co.jp
