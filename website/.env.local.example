# メール送信設定（お問い合わせフォーム）
# 未設定の場合はフォーム送信はログ出力のみになります

# ─────────────────────────────────────────
# 【本番環境（Render）】Resend を使用
# https://resend.com でアカウント作成・APIキー取得
# ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 送信元アドレス（Resendでドメイン認証済みのアドレス）
# 認証前のテスト用: onboarding@resend.dev
RESEND_FROM=noreply@shinesoft.co.jp

# ─────────────────────────────────────────
# 【ローカル開発】SMTP（nodemailer）を使用
# RESEND_API_KEY が未設定の場合にこちらが使われます
# ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@shinesoft.co.jp

# ─────────────────────────────────────────
# 共通設定
# ─────────────────────────────────────────
# 問い合わせ受信先メールアドレス（社内担当者）
CONTACT_TO_EMAIL=contact@shinesoft.co.jp
